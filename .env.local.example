# Cloudflare Web Analytics beacon token.
# Get it: Cloudflare dashboard → Analytics & Logs → Web Analytics → Add a site
# (morcecian.com.ar) → copy the token from the snippet's data-cf-beacon={"token":"..."}.
# This value is NOT secret — it ships in the page HTML.
#
# To test locally: copy this file to .env.local and fill in the token, then `npm run dev`.
NEXT_PUBLIC_CF_BEACON_TOKEN=
